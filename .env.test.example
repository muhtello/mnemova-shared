# Copy this file to .env.test and fill in real values.
# .env.test is gitignored — NEVER commit real keys.
# Values come from Supabase Dashboard → Project Settings → API.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# service_role bypasses Row-Level Security entirely. Treat it as a production
# secret: keep it out of version control, CI logs, and shared chats. Prefer
# injecting it from your shell or a CI secret store rather than this file.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
